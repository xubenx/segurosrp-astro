---
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";

const site = "https://segurosrp.com";
const canonical = `${site}/seguro-de-vida-mujer`;
const pageTitle = "Seguro de Vida Mujer | Seguros Monterrey New York Life — SegurosRP";
const pageDescription =
  "Conoce el Seguro de Vida Mujer de Seguros Monterrey New York Life: protección por fallecimiento, protección por cáncer femenino (PCF), ahorro en vida y anticipos. Asesoría nacional con firma digital.";

const business = {
  name: "Seguros Monterrey New York Life — Despacho de Asesores Ramírez y Plascencia",
  legalName: "Seguros Monterrey New York Life (asesoría independiente)",
  phone: "+52 446 135 4113",
  email: "info@segurosrp.com",
  url: canonical,
  areaServed: ["México"],
};
---

<html lang="es-MX">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    
    <!-- Google Tag Manager - Carga Diferida -->
    <script>
      // Inicializar dataLayer
      window.dataLayer = window.dataLayer || [];
      
      // Función para cargar GTM
      function loadGTM() {
        if (window.gtmLoaded) return;
        window.gtmLoaded = true;
        
        // Google Tag Manager
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-5C5DGHJC');
      }
      
      // Cargar GTM después de la primera interacción del usuario
      const events = ['mousedown', 'touchstart', 'scroll', 'keydown'];
      const loadOnce = () => {
        loadGTM();
        events.forEach(event => window.removeEventListener(event, loadOnce));
      };
      
      events.forEach(event => window.addEventListener(event, loadOnce, { passive: true }));
      
      // Fallback: cargar después de 5 segundos si no hay interacción
      setTimeout(loadGTM, 5000);
    </script>
    <!-- End Google Tag Manager -->
    
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="theme-color" content="#0A6CFF" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site}/images/og/seguro-vida-mujer.jpg`} />
    <meta property="og:site_name" content="SegurosRP" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${site}/images/og/seguro-vida-mujer.jpg`} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="es-MX" href={canonical} />

    <!-- Preload -->
    <link rel="preload" as="image" href="/principal.webp" fetchpriority="high" />

    <!-- Schema: InsuranceAgency (enfoque nacional) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "InsuranceAgency",
      "name": business.name,
      "description": pageDescription,
      "areaServed": business.areaServed,
      "telephone": business.phone,
      "email": business.email,
      "url": business.url,
      "image": `${site}/images/og/seguro-vida-mujer.jpg`,
      "sameAs": [
        "https://www.facebook.com/segurosrp/",
        "https://www.linkedin.com/company/ramirez-plascencia-despacho-de-seguros/"
      ]
    })}></script>

    <!-- Schema: Breadcrumb -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {"@type":"ListItem","position":1,"name":"Inicio","item": site},
        {"@type":"ListItem","position":2,"name":"Seguros de Vida","item": `${site}/seguros-vida`},
        {"@type":"ListItem","position":3,"name":"Seguro de Vida Mujer","item": canonical}
      ]
    })}></script>

    <!-- Schema: FAQ -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {"@type":"Question","name":"¿Qué es el Seguro de Vida Mujer de Seguros Monterrey?","acceptedAnswer":{"@type":"Answer","text":"Es un seguro de vida con enfoque femenino que combina protección por fallecimiento, protección por cáncer femenino (PCF) y ahorro en vida con entregas periódicas; además contempla anticipos por matrimonio o nacimiento/adopción y un beneficio de Apoyo en Vida en padecimientos graves definidos."}},
        {"@type":"Question","name":"¿Qué cubre la Protección por Cáncer Femenino (PCF)?","acceptedAnswer":{"@type":"Answer","text":"Indemniza un porcentaje de la suma asegurada según el órgano afectado y el estadio (p. ej. mama 100% o 47% si está localizado; ovario; útero 21% o 12% localizado; trompas 12%; tumores benignos de vagina o vulva 9%), con periodos y requisitos establecidos en condiciones."}},
        {"@type":"Question","name":"¿Hay ahorro en vida?","acceptedAnswer":{"@type":"Answer","text":"Sí. A partir del 5.º año se entregan porcentajes de la suma asegurada con periodicidad definida por año póliza, manteniendo la protección por fallecimiento durante la vigencia."}},
        {"@type":"Question","name":"¿Cuáles son las edades de contratación?","acceptedAnswer":{"@type":"Answer","text":"De 18 a 55 años (según evaluación). Algunos beneficios, como PCF o Apoyo en Vida, tienen edades y periodos específicos de cobertura definidos en condiciones."}},
        {"@type":"Question","name":"¿Puedo contratar en UDI o USD?","acceptedAnswer":{"@type":"Answer","text":"Sí. Hay versiones en UDI y dólares. La elección depende de tus objetivos (inflación vs. dolarización)."}},
        {"@type":"Question","name":"¿Atienden en todo México y con firma digital?","acceptedAnswer":{"@type":"Answer","text":"Sí. Asesoría nacional por videollamada, WhatsApp, teléfono y correo; firma electrónica disponible."}}
      ]
    })}></script>

    <!-- Accesibilidad base y utilidades -->
    <style is:global>
      .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
      :focus-visible{outline:3px solid #FF6600;outline-offset:2px}
      html{scroll-behavior:smooth}
      .gradient-bg{background:linear-gradient(135deg,#00305C 0%,#1A75CF 50%,#0052CC 100%)}
      .gradient-text{background:linear-gradient(135deg,#FF6600 0%,#FF8533 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
      .card-shadow{box-shadow:0 10px 25px -5px rgba(0,48,92,.1),0 10px 10px -5px rgba(0,48,92,.04)}
      .btn-primary{background:linear-gradient(135deg,#FF6600 0%,#FF8533 100%);transition:all .3s ease;box-shadow:0 4px 15px rgba(255,102,0,.3)}
      .btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(255,102,0,.4)}
      .btn-secondary{background:linear-gradient(135deg,#00305C 0%,#1A75CF 100%);transition:all .3s ease;box-shadow:0 4px 15px rgba(0,48,92,.3)}
      .btn-secondary:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(0,48,92,.4)}
    </style>
  </head>

  <body class="bg-gray-50 text-slate-800 antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5C5DGHJC"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    
    <a href="#contenido" class="sr-only">Saltar al contenido principal</a>

    <!-- HERO: keyword exacta -->
    <section id="inicio" class="min-h-[70vh] md:min-h-screen gradient-bg text-white relative overflow-hidden" role="region" aria-labelledby="hero-title">
      <div class="container mx-auto px-4 relative z-10">
        <div class="grid md:grid-cols-2 gap-10 items-center py-16 md:py-24">
          <div class="space-y-6">
            <div class="inline-flex items-center px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium">✨ Asesoría profesional — Servicio nacional</div>
            <h1 id="hero-title" class="text-4xl md:text-6xl font-bold leading-tight">
              Seguro de <span class="gradient-text">Vida Mujer</span>
            </h1>
            <p class="text-lg md:text-xl text-blue-100">Somos <strong>asesores certificados</strong> de <strong>Seguros Monterrey New York Life</strong>. Te explicamos y contratamos el <strong>Seguro de Vida Mujer</strong> paso a paso.</p>
            <div class="flex flex-col sm:flex-row gap-4">
              <a href="#contacto" class="btn-primary text-white px-8 py-4 rounded-full text-lg font-semibold text-center" aria-describedby="cta1-desc">💬 Hablar con un asesor</a>
              <a href="#beneficios" class="btn-secondary text-white px-8 py-4 rounded-full text-lg font-semibold text-center border-2 border-white/20">📋 Ver beneficios</a>
            </div>
            <span id="cta1-desc" class="sr-only">Abrir formulario de contacto para asesoría en Seguro de Vida Mujer</span>
          </div>
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-t from-rp-orange/20 to-transparent rounded-3xl"></div>
            <img src="/principal.webp" fetchpriority="high" loading="eager" alt="Asesoras explicando el Seguro de Vida Mujer de Seguros Monterrey New York Life" class="w-full h-auto max-h-[520px] object-contain rounded-3xl shadow-2xl" />
          </div>
        </div>
      </div>
    </section>

    <main id="contenido">
      <!-- Índice -->
      <nav aria-label="Índice de contenidos" class="bg-white border-t border-b border-gray-100">
        <div class="container mx-auto px-4 py-6">
          <ul class="flex flex-wrap gap-x-6 gap-y-3 text-sm">
            <li><a class="underline hover:no-underline" href="#beneficios">Beneficios clave</a></li>
            <li><a class="underline hover:no-underline" href="#pcf">Protección por Cáncer Femenino</a></li>
            <li><a class="underline hover:no-underline" href="#ahorro">Ahorro en vida y anticipos</a></li>
            <li><a class="underline hover:no-underline" href="#requisitos">Requisitos y periodos</a></li>
            <li><a class="underline hover:no-underline" href="#faq">Preguntas frecuentes</a></li>
          </ul>
        </div>
      </nav>

      <!-- Beneficios clave (H2→H6) -->
      <section id="beneficios" class="py-20 bg-white" aria-labelledby="h2-beneficios">
        <div class="container mx-auto px-4">
          <div class="text-center mb-14">
            <h2 id="h2-beneficios" class="text-4xl md:text-5xl font-bold mb-6">Beneficios del <span class="gradient-text">Seguro de Vida Mujer</span></h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">Protección integral con enfoque femenino y respaldo de <strong>Seguros Monterrey New York Life</strong>.</p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            <article class="bg-blue-50 rounded-3xl p-8 card-shadow">
              <h3 class="text-2xl font-semibold text-rp-blue mb-3">Protección por fallecimiento</h3>
              <h4 class="font-semibold mb-2">Respaldo a tus beneficiarios</h4>
              <p class="text-gray-700">Pago de la <strong>suma asegurada</strong> durante la vigencia del plan para sostener a tu familia y compromisos.</p>
              <h5 class="mt-3 font-semibold text-rp-blue">Usos comunes</h5>
              <p class="text-sm text-gray-600">Gastos inmediatos, hipoteca, educación e ingresos.</p>
              <h6 class="mt-2 text-slate-600 font-semibold">Vigencia</h6>
              <p class="text-sm text-gray-600">Cobertura típica a 20 años con primas niveladas.</p>
            </article>

            <article class="bg-orange-50 rounded-3xl p-8 card-shadow">
              <h3 class="text-2xl font-semibold text-rp-blue mb-3">Protección por Cáncer Femenino</h3>
              <h4 class="font-semibold mb-2">Indemnización por órgano/estadio</h4>
              <p class="text-gray-700">Porcentaje de la suma asegurada según el caso (ver tabla). Pago en una sola exhibición bajo condiciones.</p>
              <h5 class="mt-3 font-semibold text-rp-blue">Ventaja</h5>
              <p class="text-sm text-gray-600">No requiere exámenes adicionales para contratar.</p>
              <h6 class="mt-2 text-slate-600 font-semibold">Cobertura</h6>
              <p class="text-sm text-gray-600">Hasta los 70 años o fin del periodo de pago, lo que ocurra primero.</p>
            </article>

            <article class="bg-green-50 rounded-3xl p-8 card-shadow">
              <h3 class="text-2xl font-semibold text-rp-blue mb-3">Ahorro en vida</h3>
              <h4 class="font-semibold mb-2">Entregas periódicas</h4>
              <p class="text-gray-700">A partir del 5.º año se entregan <strong>porcentajes de la suma asegurada</strong> según año póliza, preservando tu protección.</p>
              <h5 class="mt-3 font-semibold text-rp-blue">Anticipos</h5>
              <p class="text-sm text-gray-600">Entre el 4.º y 5.º año, adelanto del <strong>5% de la suma asegurada</strong> por <em>matrimonio</em> o <em>nacimiento/adopción</em>.</p>
              <h6 class="mt-2 text-slate-600 font-semibold">Monedas</h6>
              <p class="text-sm text-gray-600">UDIS o USD, según estrategia.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- PCF: tabla de porcentajes -->
      <section id="pcf" class="py-20 bg-gray-50" aria-labelledby="h2-pcf">
        <div class="container mx-auto px-4">
          <div class="text-center mb-14">
            <h2 id="h2-pcf" class="text-4xl md:text-5xl font-bold mb-6">Protección por <span class="gradient-text">Cáncer Femenino</span> (PCF)</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">Indemnización proporcional a la <strong>suma asegurada</strong> de acuerdo con el órgano y el estadio del padecimiento.</p>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <article class="bg-white rounded-3xl p-8 card-shadow">
              <h3 class="text-xl font-bold mb-4 text-rp-blue">Tabla de ejemplo</h3>
              <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
                <div class="font-semibold">Mama (maligno)</div>
                <div>100% de la suma asegurada</div>
                <div class="font-semibold">Mama localizado</div>
                <div>47% de la suma asegurada</div>
                <div class="font-semibold">Ovario (maligno)</div>
                <div>38% de la suma asegurada</div>
                <div class="font-semibold">Útero (maligno)</div>
                <div>21% de la suma asegurada</div>
                <div class="font-semibold">Útero localizado</div>
                <div>12% de la suma asegurada</div>
                <div class="font-semibold">Trompas de Falopio</div>
                <div>12% de la suma asegurada</div>
                <div class="font-semibold">Benignos de vagina/vulva</div>
                <div>9% de la suma asegurada</div>
              </div>
              <p class="text-xs text-gray-500 mt-4">*Porcentajes ilustrativos con base en condiciones del plan. Consulta tu versión y póliza para detalles completos.</p>
            </article>

            <article class="bg-white rounded-3xl p-8 card-shadow">
              <h3 class="text-xl font-bold mb-4 text-rp-blue">Características clave</h3>
              <ul class="list-disc pl-6 text-sm text-gray-700 space-y-2">
                <li><strong>Edades:</strong> contratación de 18 a 55 años (riesgo normal); cobertura hasta 70 años o fin del periodo de pago.</li>
                <li><strong>Carencia:</strong> 6 meses para nuevos padecimientos cubiertos.</li>
                <li><strong>Supervivencia:</strong> recurrencias en el mismo órgano dentro de 3 años se consideran el mismo evento.</li>
                <li><strong>Requisitos de indemnización:</strong> HP/HC/HQ/US y formatos de reclamación.</li>
                <li><strong>Pago:</strong> en una sola exhibición; suma de pagos limitada por condiciones vigentes.</li>
              </ul>
              <h4 class="font-semibold mt-4 text-rp-blue">Moneda y suma</h4>
              <p class="text-sm text-gray-700">Versiones en UDI o USD. Los límites de suma asegurada para PCF no pueden exceder la suma asegurada del plan básico.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- Ahorro en vida y anticipos -->
      <section id="ahorro" class="py-20 bg-white" aria-labelledby="h2-ahorro">
        <div class="container mx-auto px-4">
          <div class="text-center mb-14">
            <h2 id="h2-ahorro" class="text-4xl md:text-5xl font-bold mb-6">Ahorro en <span class="gradient-text">Vida</span> y Anticipos</h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">Recibe porcentajes de tu suma asegurada desde el 5.º año y anticipos por eventos familiares.</p>
          </div>

          <div class="grid md:grid-cols-2 gap-8">
            <article class="bg-white rounded-3xl p-8 card-shadow">
              <h3 class="text-xl font-bold mb-4 text-rp-blue">Entregas por año póliza</h3>
              <p class="text-gray-700">A partir del año 5 se entregan porcentajes definidos (p. ej. 5% en años 5, 7, 9, 11, 13, 15, 17…), manteniendo la protección por fallecimiento durante la vigencia.</p>
              <h4 class="font-semibold mt-4 text-rp-blue">Primas</h4>
              <p class="text-sm text-gray-700">Niveladas durante 20 años.</p>
              <h5 class="font-semibold mt-4 text-rp-blue">Monedas</h5>
              <p class="text-sm text-gray-700">UDIS o USD.</p>
              <h6 class="font-semibold mt-4 text-rp-orange">Nota</h6>
              <p class="text-xs text-gray-600">La tabla exacta de porcentajes puede variar por versión; te la entregamos en la cotización.</p>
            </article>

            <article class="bg-white rounded-3xl p-8 card-shadow">
              <h3 class="text-xl font-bold mb-4 text-rp-blue">Anticipos por eventos familiares</h3>
              <ul class="list-disc pl-6 text-sm text-gray-700 space-y-2">
                <li><strong>Matrimonio o nacimiento/adopción:</strong> entre el 4.º y 5.º año, anticipo del <strong>5% de la suma asegurada</strong>.</li>
                <li><strong>Apoyo en Vida (padecimientos graves):</strong> anticipo de hasta <strong>25% de la suma asegurada</strong> o <strong>$700,000 MXN</strong>, lo que resulte menor; aplica en supuestos definidos (p. ej., infarto agudo al miocardio o accidente cerebrovascular) y en ciertos estados de salud terminal.</li>
              </ul>
              <p class="text-xs text-gray-600 mt-3">*La entrega de anticipos reduce la suma asegurada en la misma proporción; las primas se mantienen conforme a condiciones.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- Requisitos y periodos -->
      <section id="requisitos" class="py-20 bg-gray-50" aria-labelledby="h2-requisitos">
        <div class="container mx-auto px-4">
          <div class="text-center mb-14">
            <h2 id="h2-requisitos" class="text-4xl md:text-5xl font-bold mb-6">Requisitos y <span class="gradient-text">Periodos</span></h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">Lo esencial para evaluar tu contratación y uso de beneficios.</p>
          </div>

          <div class="grid md:grid-cols-3 gap-8">
            <article class="bg-white rounded-3xl p-8 card-shadow">
              <h3 class="text-2xl font-semibold text-rp-blue mb-3">Edades</h3>
              <h4 class="font-semibold mb-2">Contratación</h4>
              <p class="text-gray-700">De <strong>18</strong> a <strong>55</strong> años (según selección de riesgo).</p>
              <h5 class="mt-3 font-semibold text-rp-blue">PCF</h5>
              <p class="text-sm text-gray-600">Cobertura hasta <strong>70</strong> años o fin del periodo de pago.</p>
              <h6 class="mt-2 text-slate-600 font-semibold">Vigencia</h6>
              <p class="text-sm text-gray-600">Plan típico a 20 años.</p>
            </article>

            <article class="bg-white rounded-3xl p-8 card-shadow">
              <h3 class="text-2xl font-semibold text-rp-blue mb-3">Moneda y sumas</h3>
              <h4 class="font-semibold mb-2">Disponibles</h4>
              <p class="text-gray-700"><strong>UDIS</strong> o <strong>USD</strong>.</p>
              <h5 class="mt-3 font-semibold text-rp-blue">Mínimos de referencia</h5>
              <p class="text-sm text-gray-600">Desde <strong>10,000 USD</strong> o <strong>35,000 UDIS</strong>; máximos sujetos a políticas y reaseguro y a no exceder los límites del plan básico.</p>
              <h6 class="mt-2 text-slate-600 font-semibold">Documentación</h6>
              <p class="text-sm text-gray-600">Identificación, solicitud y cuestionario médico según corresponda.</p>
            </article>

            <article class="bg-white rounded-3xl p-8 card-shadow">
              <h3 class="text-2xl font-semibold text-rp-blue mb-3">Tiempos y condiciones</h3>
              <h4 class="font-semibold mb-2">Carencia</h4>
              <p class="text-gray-700"><strong>6 meses</strong> para padecimientos cubiertos en PCF.</p>
              <h5 class="mt-3 font-semibold text-rp-blue">Supervivencia</h5>
              <p class="text-sm text-gray-600">Recurrencias en el mismo órgano dentro de <strong>3 años</strong> se consideran el mismo evento.</p>
              <h6 class="mt-2 text-slate-600 font-semibold">Indemnización</h6>
              <p class="text-sm text-gray-600">Pago en una sola exhibición conforme a tabla y límites de póliza.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- FAQs -->
      <section id="faq" class="py-20 bg-white" aria-labelledby="h2-faq">
        <div class="container mx-auto px-4">
          <div class="text-center mb-14">
            <h2 id="h2-faq" class="text-4xl md:text-5xl font-bold mb-6">Preguntas <span class="gradient-text">Frecuentes</span></h2>
            <p class="text-xl text-gray-600 max-w-3xl mx-auto">Dudas comunes sobre el <strong>Seguro de Vida Mujer</strong>.</p>
          </div>

          <div class="max-w-4xl mx-auto space-y-6">
            <details class="bg-gray-50 rounded-3xl p-8 card-shadow group">
              <summary class="cursor-pointer text-xl font-semibold flex items-center justify-between text-rp-blue group-open:text-rp-orange transition-colors">
                <span>🧾 ¿El seguro de vida mujer incluye ahorro?</span>
